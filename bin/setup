#!/bin/bash
set -euo pipefail
set -x

DIRNAME="$(basename "$(pwd)")"
if brew tap | grep -x "gnc178/$DIRNAME"; then
  brew untap "gnc178/$DIRNAME" --force
fi
brew tap "gnc178/$DIRNAME" .
rm -rf "$(brew --repo)/Library/Taps/gnc178/homebrew-$DIRNAME"
ln -sf "$(pwd)" "$(brew --repo)/Library/Taps/gnc178/homebrew-$DIRNAME"
